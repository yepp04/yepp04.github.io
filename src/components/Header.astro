---
const currentPath = Astro.url.pathname;
---

<header>
  <nav>
    <a href="/blog" class="logo">깃냥이.DEV</a>
    <div class="nav-links">
      <a href="/blog" class:list={[{ active: currentPath.startsWith('/blog') }]}>Blog</a>
      <a href="/about" class:list={[{ active: currentPath.startsWith('/about') }]}>About</a>
      <a href="https://github.com/yepp04" target="_blank" rel="noopener noreferrer">GitHub</a>
    </div>
  </nav>
</header>

<style>
  header {
    border-bottom: 1px solid var(--border);
    position: sticky;
    top: 0;
    background-color: var(--bg);
    z-index: 100;
    backdrop-filter: blur(8px);
  }

  nav {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 1rem 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo {
    font-family: 'Pretendard Variable', 'Pretendard', sans-serif;
    font-size: 1.2rem;
    font-weight: 500;
    color: var(--text);
    letter-spacing: -0.5px;
    line-height: 1.5;
    white-space: nowrap;
  }

  .nav-links {
    display: flex;
    gap: 1.5rem;
  }

  .nav-links a {
    color: var(--text-muted);
    font-size: 0.9rem;
    transition: color 0.2s;
  }

  .nav-links a:hover,
  .nav-links a.active {
    color: var(--text);
  }
</style>
